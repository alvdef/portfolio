{
  "name": "utilitarian-portfolio",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "sync:content": "node scripts/sync-content.mjs",
    "check:content": "node scripts/check-content-freshness.mjs",
    "lint": "eslint . --ext .js,.mjs,.cjs,.ts,.tsx,.astro",
    "lint:fix": "npm run lint -- --fix",
    "predev": "npm run sync:content",
    "dev": "npm run check:content && astro dev",
    "prebuild": "npm run sync:content",
    "build": "npm run check:content && astro build",
    "preview": "astro preview"
  },
  "dependencies": {
    "@astrojs/react": "^4.4.0",
    "@tailwindcss/vite": "^4.1.12",
    "@vercel/node": "^5.3.0",
    "astro": "^5.13.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "tailwindcss": "^4.1.12"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "astro-eslint-parser": "^1.3.0",
    "eslint": "^10.0.1",
    "eslint-plugin-astro": "^1.6.0",
    "globals": "^17.3.0",
    "typescript-eslint": "^8.56.0"
  }
}
