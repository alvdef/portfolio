---
import { ClientRouter } from 'astro:transitions';
import HeaderCarousel from '@/components/HeaderCarousel.astro';
import Sidebar from '@/components/Sidebar.astro';
import PeekSnap from '@/components/PeekSnap';
import '@/styles/global.css';

interface Props {
  title: string;
  currentSection: string;
  sections: string[];
  sectionLinks?: Record<string, string>;
  sectionGroups: Array<{ group: string; items: Array<{ data: { title: string; slug: string; section: string } }> }>;
  currentSlug: string;
  prevUrl: string | null;
  nextUrl: string | null;
  articleIndex?: number;
  articleTotal?: number;
}

const { title, currentSection, sections, sectionLinks = {}, sectionGroups, currentSlug, prevUrl, nextUrl, articleIndex, articleTotal } = Astro.props;
---

<!doctype html>
<html lang="en" data-nav-dir="none" data-nav-axis="none">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <script is:inline>
      (() => {
        const stored = localStorage.getItem('theme');
        const nextTheme = stored || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        document.documentElement.dataset.theme = nextTheme;
      })();
    </script>
    <ClientRouter />
  </head>
  <body>
    <div class="app-grid">
      <HeaderCarousel sections={sections} sectionLinks={sectionLinks} currentSection={currentSection} />

      <Sidebar groups={sectionGroups} currentSlug={currentSlug} />

      <main class="content-pane" data-prev-url={prevUrl ?? ''} data-next-url={nextUrl ?? ''}>
        <slot />
      </main>
      <PeekSnap client:load />
    </div>

    {articleIndex && articleTotal && (
      <div class="status-line">
        <span class="status-breadcrumb">{currentSection}/{currentSlug} [{articleIndex}/{articleTotal}]</span>
        <span class="status-keys">h/l sections · j/k articles</span>
        <span class="status-credit">Álvaro de Francisco &copy; 2026</span>
      </div>
    )}

    <script>
      import { initNavigationController, resetNavigationAfterSwap } from '@/scripts/nav-controller';
      import { initSidebarController, syncSidebarForViewport } from '@/scripts/sidebar-controller';
      import { initThemeController, syncThemeAfterSwap } from '@/scripts/theme-controller';

      initNavigationController();
      initSidebarController();
      initThemeController();

      const afterSwapBound = (window).__portfolioAfterSwapBound === true;
      if (!afterSwapBound) {
        document.addEventListener('astro:after-swap', () => {
          resetNavigationAfterSwap();
          syncThemeAfterSwap();
          syncSidebarForViewport();
        });
        (window).__portfolioAfterSwapBound = true;
      }
    </script>
  </body>
</html>
