---
import { render } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getPublishedDocs, groupDocsByGroup } from '@/lib/content';
import { getSectionLandingLinks } from '@/scripts/section-links';
import { SECTIONS } from '@/generated/sections';
import YoutubePlaylistTable from '@/components/YoutubePlaylistTable';

export async function getStaticPaths() {
  const docs = await getPublishedDocs();
  return docs.map((doc) => ({
    params: {
      section: doc.data.section,
      slug: doc.data.slug
    },
    props: { doc }
  }));
}

const { doc } = Astro.props;
const isVirtualDoc = doc.collection === 'virtual';
const isYoutubeVirtualDoc = isVirtualDoc && doc.data.section === 'about_me' && doc.data.slug === 'youtube';
const rendered = !isVirtualDoc ? await render(doc) : null;
const Content = rendered?.Content ?? null;

const docs = await getPublishedDocs();
const sectionDocs = docs.filter((d) => d.data.section === doc.data.section);
const sectionGroups = groupDocsByGroup(sectionDocs);
const sectionLinks = getSectionLandingLinks(docs, [...SECTIONS]);

const index = sectionDocs.findIndex((d) => d.id === doc.id);
const prevDoc = index > 0 ? sectionDocs[index - 1] : null;
const nextDoc = index < sectionDocs.length - 1 ? sectionDocs[index + 1] : null;
---

<BaseLayout
  title={doc.data.title}
  currentSection={doc.data.section}
  sections={[...SECTIONS]}
  sectionLinks={sectionLinks}
  sectionGroups={sectionGroups}
  currentSlug={doc.data.slug}
  prevUrl={prevDoc ? `/${prevDoc.data.section}/${prevDoc.data.slug}` : null}
  nextUrl={nextDoc ? `/${nextDoc.data.section}/${nextDoc.data.slug}` : null}
  articleIndex={index + 1}
  articleTotal={sectionDocs.length}
>
  <article
    id="article-scroll-root"
    class="article-body"
    data-next-url={nextDoc ? `/${nextDoc.data.section}/${nextDoc.data.slug}` : ''}
    data-prev-url={prevDoc ? `/${prevDoc.data.section}/${prevDoc.data.slug}` : ''}
    data-next-title={nextDoc?.data.title ?? ''}
    data-next-meta={nextDoc ? `${nextDoc.data.group} / ${new Date(nextDoc.data.date).toISOString().slice(0, 10)}` : ''}
    data-prev-title={prevDoc?.data.title ?? ''}
    data-prev-meta={prevDoc ? `${prevDoc.data.group} / ${new Date(prevDoc.data.date).toISOString().slice(0, 10)}` : ''}
  >
    <header class="article-header">
      <h1>{doc.data.title}</h1>
      <p class="meta">{doc.data.group} / {new Date(doc.data.date).toISOString().slice(0, 10)}</p>
    </header>
    {
      isYoutubeVirtualDoc ? (
        <section class="youtube-directory">
          <p class="youtube-intro">Index of /codice/cl</p>
          <YoutubePlaylistTable client:load />
        </section>
      ) : Content ? (
        <Content />
      ) : (
        <p>Virtual document has no renderer.</p>
      )
    }
  </article>
</BaseLayout>
